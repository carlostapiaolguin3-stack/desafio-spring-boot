        {
            "name": "4. Seguridad (Rate Limit)",
            "item": [
                {
                    "name": "Prueba de Carga Rápida (Ejecutar varias veces)",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "if (pm.response.code === 429) {",
                                    "    pm.test(\"Rate Limit detectado correctamente\", function () {",
                                    "        pm.expect(pm.response.code).to.equal(429);",
                                    "    });",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/api/tasks",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "tasks"
                            ]
                        },
                        "description": "Llama a este endpoint rápidamente (manual o runner) para disparar el error 429."
                    },
                    "response": []
